<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - woolly_friends</title>
    <link rel="icon" href="~/images/Logo.png" />

    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;700&family=Source+Serif+Pro:wght@700&display=swap" rel="stylesheet">
</head>
<body class="min-h-screen font-inter bg-gray-50">

    <div class="min-h-screen flex flex-col">
        <!-- Header -->
        <header class="relative bg-[#684034] h-[62px] overflow-hidden">
            <div class="absolute left-1/2 transform -translate-x-1/2 top-[-13px]">
                <img src="~/images/Logo.png" alt="Logo" class="h-20" />
            </div>

            <!-- Confetti Icons -->
            <img class="absolute left-[484px] top-[32px] w-[10px]" src="~/images/ConfettiHeart.svg" />
            <img class="absolute left-[512.17px] top-[33.83px] w-[10px] rotate-[-190deg]" src="~/images/SingleConfetti.svg" />
            <img class="absolute left-[568.38px] top-[4.96px] w-[10px] rotate-[40deg]" src="~/images/ConfettiHeart.svg" />
            <img class="absolute left-[548px] top-[29px] w-[10px] rotate-[80deg]" src="~/images/SingleConfetti.svg" />
            <img class="absolute left-[584px] top-[39px] w-[10px]" src="~/images/SingleConfetti.svg" />
            <img class="absolute left-[858.99px] top-[33.41px] w-[10px] rotate-[-160deg]" src="~/images/SingleConfetti.svg" />
            <img class="absolute left-[873.01px] top-[10.59px] w-[10px] rotate-[20deg]" src="~/images/ConfettiHeart.svg" />
            <img class="absolute left-[886px] top-[36px] w-[10px]" src="~/images/SingleConfetti.svg" />
            <img class="absolute left-[925.38px] top-[26.96px] w-[10px] rotate-[40deg]" src="~/images/SingleConfetti.svg" />
            <img class="absolute left-[948px] top-[22px] w-[10px]" src="~/images/ConfettiHeart.svg" />
        </header>

        <!-- Navbar Toggle & Menu -->
        <nav class="bg-gray-100 shadow-sm border-b px-4 py-2 flex items-center">
            <button id="toggleSidebar" class="text-gray-700 font-semibold text-sm border px-3 py-1 rounded">
                <i class="bi bi-list"></i>
                MENU
            </button>

            <button class="ml-auto text-sm flex items-center gap-1 border px-2 py-1 rounded text-gray-700 hover:text-pink-600">
                <i class="bi bi-heart-fill"></i>
                <span class="uppercase font-bold">Wishlist</span>
            </button>
        </nav>

        <div class="flex flex-1">
            <!-- Sidebar -->
            <aside id="sidebar" class="w-64 bg-white border-r p-4 transition-all duration-500">
                <ul class="space-y-4 font-semibold text-gray-800">
                    <li><a href="/Home" class="hover:text-rose-600">Home</a></li>
                    <li><a href="/Login" class="hover:text-rose-600">Login</a></li>
                    <li><a href="/SignUp" class="hover:text-rose-600">Sign Up</a></li>
                    <li><a href="/Profile" class="hover:text-rose-600">Profile</a></li>
                    <li><a href="/Profile/PetsPage" class="hover:text-rose-600">Pets Page</a></li>
                    <li><a href="/Profile/Orders" class="hover:text-rose-600">Orders</a></li>
                    <li><a href="/Profile/Reviews" class="hover:text-rose-600">Reviews</a></li>
                </ul>
            </aside>

            <!-- Main Content -->
            <main class="flex-1 p-6">
                @RenderBody()
            </main>
        </div>

        <!-- Footer -->
        <footer class="bg-[#684034] text-white text-sm py-4 px-6 flex flex-wrap justify-center gap-4 md:gap-20">
            <span>&copy; 2025 Woolly Friends</span>
            <span>Follow us on Social Media!</span>
            <span>Contact us: woollyfriends@gmail.com</span>
            <a href="/Home/Privacy" class="underline">Privacy</a>
        </footer>
    </div>

    <!-- Sidebar -->
    <script>
        document.getElementById('toggleSidebar').addEventListener('click', function () {
            const sidebar = document.getElementById('sidebar');
            sidebar.classList.toggle('hidden');
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
