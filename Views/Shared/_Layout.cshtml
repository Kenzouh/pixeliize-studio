                            <li><a asp-area="" asp-controller="SignUp" asp-action="Index" class="text-gray-700 hover:text-black">Sign Up</a></li>
                            <li><a asp-area="" asp-controller="Profile" asp-action="Index" class="text-gray-700 hover:text-black">Profile</a></li>
                            <li><a asp-area="" asp-controller="Profile" asp-action="PetsPage" class="text-gray-700 hover:text-black">Pets Page</a></li>
                            <li><a asp-area="" asp-controller="Profile" asp-action="Orders" class="text-gray-700 hover:text-black">Orders</a></li>
                            <li><a asp-area="" asp-controller="Profile" asp-action="Reviews" class="text-gray-700 hover:text-black">Reviews</a></li>
                        </ul>
                    </div>
                </div>
            </div>
