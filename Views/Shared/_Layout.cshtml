    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const toggle = document.getElementById("nav-toggle");
            const menu = document.getElementById("nav-menu");

            toggle.addEventListener("click", () => {
                menu.classList.toggle("hidden");
            });
        });
