<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - woolly_friends</title>
    <link rel="icon" href="~/images/Logo.png" />

    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;700&family=Source+Serif+Pro:wght@700&display=swap" rel="stylesheet">
</head>
<body class="min-h-screen font-inter bg-gray-50">

    <div class="min-h-screen flex flex-col">
        <!-- Header -->
        <header class="relative bg-[#684034] h-[62px] overflow-hidden">
            <div class="absolute left-1/2 transform -translate-x-1/2 top-[-13px]">
                <img src="~/images/Logo.png" alt="Logo" class="h-20" />
            </div>

            <!-- Navbar Toggle & Menu -->
            <nav class="px-7 py-4 flex justify-between w-full">
                <button id="toggleSidebar" class="text-white font-semibold text-md hover:text-gray-300 flex items-center gap-1">
                    <i class="bi bi-list text-2xl"></i>
                    MENU
                </button>

                <button class="text-white text-md border-white border-2 lg:rounded-full  hover:border-gray-300 hover:text-gray-300 px-2">
                    <span class="uppercase font-bold">Add Listing</span>
                </button>
            </nav>

        </header>


        <div class="flex flex-1">
            <!-- Sidebar -->
            <aside id="sidebar" class="hidden w-64 bg-white border-r p-4 transition-all duration-500">
                <ul class="space-y-4 font-semibold text-gray-800">
                    <li><a href="/Home" class="hover:text-rose-600">Home</a></li>
                    <li><a href="/Login" class="hover:text-rose-600">Login</a></li>
                    <li><a href="/SignUp" class="hover:text-rose-600">Sign Up</a></li>
                    <li><a href="/Profile" class="hover:text-rose-600">Profile</a></li>
                    <li><a href="/Profile/PetsGallery" class="hover:text-rose-600">Pets Gallery</a></li>
                    <li><a href="/Profile/PetsPage" class="hover:text-rose-600">Pets Page</a></li>
                </ul>
            </aside>

            <!-- Main Content -->
            <main class="flex-1 p-6">
                @RenderBody()
            </main>
        </div>

        <!-- Footer -->
        <footer class="bg-[#684034] text-white text-sm py-4 px-6 flex flex-wrap justify-center gap-4 md:gap-20">
            <span>&copy; 2025 Woolly Friends</span>
            <span>Follow us on Social Media!</span>
            <span>Contact us: woollyfriends@gmail.com</span>
            <a href="/Home/Privacy" class="underline">Privacy</a>
        </footer>
    </div>

    <!-- Sidebar -->
    <script>
        document.getElementById('toggleSidebar').addEventListener('click', function () {
            const sidebar = document.getElementById('sidebar');
            sidebar.classList.toggle('hidden');
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
