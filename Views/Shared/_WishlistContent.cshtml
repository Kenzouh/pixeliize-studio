<div class="w-full md:w-3/4 p-3 grid grid-cols-1 md:grid-cols-3 gap-4">
    @for (int i = 0; i < 3; i++)
    {
        <!-- Outer wrapper -->
        <div class="relative bg-white rounded-lg shadow-sm overflow-hidden">

            <!-- Favorite Icon  -->
            <div class="absolute top-2 right-2 w-10 h-10 bg-white rounded-full flex items-center justify-center shadow cursor-pointer">
                <i class="bi bi-suit-heart text-red-600 text-xl"></i>
            </div>

            <!-- Hoverable inner card -->
            <div class="relative rounded-lg overflow-hidden shadow-lg hover:scale-105 hover:shadow-2xl hover:z-10 hover:cursor-pointer
                         transform transition duration-300 ease-in-out">

                <!-- Pet Image -->
                <img src="~/images/Chewy.jpg" alt="Dog" class="w-full h-64 object-cover">

                <!-- Heart Icon Inside -->
                <div class="absolute top-2 right-2 w-10 h-10 bg-white rounded-full flex items-center justify-center shadow cursor-pointer">
                    <i class="bi bi-suit-heart text-red-600 text-xl"></i>
                </div>

                <!-- Pet Info -->
                <div class="bg-white px-4 pt-4 pb-2">
                    <h3 class="font-bold text-[#684034] sm:p-1 xl:text-3xl">Name</h3>
                    <p class="text-black flex items-center gap-1 sm:p-1">Breed</p>
                    <p class="text-blue-700 sm:p-1">Gender</p>
                    <p class="text-black sm:p-1">Age</p>
                    <div class="font-bold text-green-700 sm:p-1">&#8369;5,000</div>
                </div>
            </div>
        </div>
    }
</div>
