<!-- _FilterSidebar.cshtml -->
<aside class="w-[240px] bg-[#d0b1b1] p-5 rounded-md shadow-lg sticky top-4 hidden md:block">
    @Html.Partial("_FilterSidebarInner")
</aside>

<!-- Mobile Button -->
<div class="md:hidden mb-4">
    <button onclick="toggleFilterSidebar()" class="bg-[#c39383] px-4 py-2 rounded-md text-white font-semibold">
        Filter
    </button>
</div>

<!-- Mobile Sidebar Drawer -->
<div id="mobileFilterSidebar" class="fixed inset-0 z-50 bg-black bg-opacity-50 hidden md:hidden">
    <div class="bg-white w-[80%] h-full p-5 overflow-y-auto">
        <div class="flex justify-between items-center mb-4">
            <h4 class="text-lg font-bold">Filters</h4>
            <button onclick="toggleFilterSidebar()" class="text-2xl font-bold">&times;</button>
        </div>
        @Html.Partial("_FilterSidebarInner")
    </div>
</div>

@section Scripts {
    <script>
        function toggleFilterSidebar() {
            const sidebar = document.getElementById("mobileFilterSidebar");
            sidebar.classList.toggle("hidden");
        }
    </script>
}
