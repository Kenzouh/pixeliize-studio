@model woolly_friends.Models.Tables.User

<!DOCTYPE html>
<html lang="en">

<head>
    <title>Profile</title>
    <meta charset="utf-8" />
    <meta name="description" content="Profile page with user credentials." />
    <meta name="keywords" content="Profile, User" />
    <meta name="author" content="Kenzo, Lawrenz, John Cee, Jericho, George" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-white font-sans">

    <!-- Profile -->



    <hr class="mt-6 border border-[#412c25]" />


    <!-- Buttons -->
    <div class="flex flex-wrap gap-2 mt-6 px-4 justify-center sm:justify-start">
        <button class="bg-[#c39383] text-[#241612] border border-[#684034] rounded-lg font-black text-lg min-w-[180px] h-[50px] hover:bg-[#b58778]" onclick="window.location.href='/Profile/Index'">Products</button>
        <button class="bg-[#c39383] text-[#241612] border border-[#684034] rounded-lg font-black text-lg min-w-[180px] h-[50px] hover:bg-[#b58778]" onclick="window.location.href='/Profile/Orders'">Orders</button>
        <button class="bg-[#c39383] text-[#241612] border border-[#684034] rounded-lg font-black text-lg min-w-[180px] h-[50px] hover:bg-[#b58778]" onclick="window.location.href='/Profile/Reviews'">Reviews</button>
        <button class="bg-[#c39383] text-[#241612] border border-[#684034] rounded-lg font-black text-lg min-w-[180px] h-[50px] hover:bg-[#b58778]" onclick="window.location.href='/Profile/UserManagement'">User Management</button>
    </div>

    <!-- Header -->
    @Html.Partial("_SearchBarHeader")

    <!-- Layout container -->
    <div class="container mx-auto mt-8 px-4 flex flex-col md:flex-row gap-4">

        <!-- Filter Sidebar -->
        <div class="w-full md:w-[240px] shrink-0">
            @Html.Partial("_FilterSidebar")
        </div>

        <!-- Orders content -->
        <div class="flex-1">
            <!-- This can show a list of pet orders -->
            @Html.Partial("_WishlistContent")
        </div>
    </div>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            document.querySelectorAll('.bi-suit-heart, .bi-suit-heart-fill').forEach(function (icon) {
                icon.addEventListener('click', function () {
                    this.classList.toggle('bi-suit-heart');
                    this.classList.toggle('bi-suit-heart-fill');
                });
            });
        });

        function toggleFilterSidebar() {
            const sidebar = document.getElementById('mobileFilterSidebar');
            sidebar.classList.toggle('hidden');
        }
    </script>

    <script src="~/js/main.js"></script>
</body>

</html>
