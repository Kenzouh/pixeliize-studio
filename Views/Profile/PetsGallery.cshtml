<!DOCTYPE html>
<html lang="en">

<head>
    <title>Profile | Pets</title>

    <!-- Pre-requisite Meta Tags -->
    <meta charset="utf-8" />
    <meta name="description" content="Pets page showing the pets." />
    <meta name="keywords" content="Wishlist, Orders, Pets" />
    <meta name="author" content="Kenzo, Lawrenz, John Cee, Jericho, George" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />

    <script src="https://cdn.tailwindcss.com"></script>
    <link href="~/css/main.css" rel="stylesheet" media="all" />
</head>

<body>

    <!-- Header -->
    <div class="container mx-auto mt-4 px-4">
        <div class="flex justify-between items-center">

            <div class="flex items-center gap-3">
                <h3>
                    Displaying <span class="font-bold">1</span> to <span class="font-bold">39</span> of <span class="font-bold">538</span> pets
                </h3>
                <h3 class="underline text-gray-400 hover:text-gray-600 sm:p-2">Clear all 3 filters</h3>
            </div>

            <div class="flex items-center gap-2">
                <h3 class="font-bold">Show</h3>
                <select name="page" id="page" class="border rounded px-2 py-1 border-black border-2">
                    <option value="1">1</option>
                    <option value="2">2</option>
                    <option value="3">3</option>
                    <option value="4">4</option>
                </select>
                <h3 class="font-bold">pets per page</h3>
            </div>
        </div>
    </div>


    <!-- Filter + Pet Cards -->
    <div class="container mx-auto mt-8 px-4 flex flex-wrap">
        <!-- Filter Sidebar -->
        <aside class="w-full md:w-1/4 bg-white p-5">
            <h4 class="font-bold text-lg flex items-center mb-4">Refine your search <i class="bi bi-filter ml-2"></i></h4>

            <div class="mb-4">
                <h6 class="font-bold mb-2">Species</h6>
                <label class="block"><input type="checkbox" class="mr-2">Cats (0)</label>
                <label class="block"><input type="checkbox" class="mr-2">Dogs (0)</label>
                <label class="block"><input type="checkbox" class="mr-2">Other Pets (0)</label>
            </div>

            <div class="mb-4">
                <h6 class="font-bold mb-2">Gender</h6>
                <label class="block"><input type="checkbox" class="mr-2">Male (0)</label>
                <label class="block"><input type="checkbox" class="mr-2">Female (0)</label>
            </div>

            <div class="mb-4">
                <h6 class="font-bold mb-2">Size</h6>
                <label class="block"><input type="checkbox" class="mr-2">Small (0)</label>
                <label class="block"><input type="checkbox" class="mr-2">Medium (0)</label>
                <label class="block"><input type="checkbox" class="mr-2">Large (0)</label>
            </div>

            <div>
                <h6 class="font-bold mb-2">Price</h6>
                <div class="flex gap-2">
                    <input type="text" placeholder="Min" class="w-1/2 border p-2" />
                    <input type="text" placeholder="Max" class="w-1/2 border p-2" />
                </div>
            </div>
        </aside>

