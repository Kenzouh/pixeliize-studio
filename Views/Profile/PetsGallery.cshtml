        <div class="w-full md:w-3/4 p-3 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
            <!-- Card 1 -->
            <div class="relative rounded-lg overflow-hidden shadow-sm">
                <img src="~/images/Chewy.jpg" alt="Dog" class="w-full h-64 object-cover">
