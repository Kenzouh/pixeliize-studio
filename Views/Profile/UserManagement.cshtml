                    </div>
                </div>
            </div>

            <!-- Table Headers -->
            <div class="overflow-x-auto">
                <table class="w-full min-w-[1000px]" data-sort-direction="asc">
                    <thead class="bg-[#D0C4C0] text-black">
                        <tr class="border-b border-gray-300 text-sm">
                            <th class="px-6 py-3 text-left font-semibold cursor-pointer" onclick="sortTable(0)">
                                <div class="flex items-center space-x-1">
                                    <span>ID</span>
                                    <div class="flex flex-col">
                                        <i class="fas fa-caret-up text-xs -mb-1"></i>
                                        <i class="fas fa-caret-down text-xs"></i>
                                    </div>
                                </div>
                            </th>
                            <th class="px-6 py-3 text-left font-semibold cursor-pointer" onclick="sortTable(1)">
                                <div class="flex items-center space-x-1">
                                    <span>First Name</span>
                                    <div class="flex flex-col">
                                        <i class="fas fa-caret-up text-xs -mb-1"></i>
                                        <i class="fas fa-caret-down text-xs"></i>
                                    </div>
                                </div>
                            </th>
                            <th class="px-6 py-3 text-left font-semibold cursor-pointer" onclick="sortTable(2)">
                                <div class="flex items-center space-x-1">
                                    <span>Last Name</span>
                                    <div class="flex flex-col">
                                        <i class="fas fa-caret-up text-xs -mb-1"></i>
                                        <i class="fas fa-caret-down text-xs"></i>
                                    </div>
                                </div>
                            </th>
                            <th class="px-6 py-3 text-left font-semibold">Birthday</th>
                            <th class="px-6 py-3 text-left font-semibold">Number</th>
                            <th class="px-6 py-3 text-left font-semibold">Email</th>
                            <th class="px-6 py-3 text-left font-semibold">Address</th>
                            <th class="px-6 py-3 text-left font-semibold">Action</th>
                        </tr>
                    </thead>
                    <tbody id="userTableBody" class="text-sm text-black">
                        <!-- Sample rows. Hindi pa sya connected sa db, ikaw na bahala dito George HAHAHHA -->
                        <tr class="border-b border-gray-200 hover:bg-gray-50 even:bg-gray-50 transition">
                            <td class="px-6 py-4">1</td>
                            <td class="px-6 py-4">George</td>
                            <td class="px-6 py-4">Ditan</td>
                            <td class="px-6 py-4">03/15/1999</td>
                            <td class="px-6 py-4">09123456789</td>
                            <td class="px-6 py-4">georgeedcaluag@gmail.com</td>
                            <td class="px-6 py-4">LRT PUREZA</td>
                            <td class="px-6 py-4">
                                <div class="flex space-x-2">
                                    <button class="bg-orange-500 hover:bg-orange-600 text-white px-4 py-1.5 rounded-md text-sm font-semibold transition">
                                        <i class="fas fa-ban mr-1"></i>Deactivate
                                    </button>
                                    <button class="bg-red-500 hover:bg-red-600 text-white px-4 py-1.5 rounded-md text-sm font-semibold transition">
                                        <i class="fas fa-trash mr-1"></i>Delete
                                    </button>
                                </div>
                            </td>
                        </tr>
                        <tr class="border-b border-gray-200 hover:bg-gray-50 even:bg-gray-50 transition">
                            <td class="px-6 py-4">2</td>
                            <td class="px-6 py-4">Edward</td>
                            <td class="px-6 py-4">Itan</td>
                            <td class="px-6 py-4">03/15/1999</td>
                            <td class="px-6 py-4">09123456789</td>
                            <td class="px-6 py-4">georgeedcaluag@gmail.com</td>
                            <td class="px-6 py-4">PUREZA</td>
                            <td class="px-6 py-4">
                                <div class="flex space-x-2">
                                    <button class="bg-orange-500 hover:bg-orange-600 text-white px-4 py-1.5 rounded-md text-sm font-semibold transition">
                                        <i class="fas fa-ban mr-1"></i>Deactivate
                                    </button>
                                    <button class="bg-red-500 hover:bg-red-600 text-white px-4 py-1.5 rounded-md text-sm font-semibold transition">
                                        <i class="fas fa-trash mr-1"></i>Delete
                                    </button>
                                </div>
                            </td>
                        </tr>
                        <tr class="border-b border-gray-200 hover:bg-gray-50 even:bg-gray-50 transition">
                            <td class="px-6 py-4">3</td>
                            <td class="px-6 py-4">Gorgie</td>
                            <td class="px-6 py-4">Tan</td>
                            <td class="px-6 py-4">03/15/1999</td>
                            <td class="px-6 py-4">09123456789</td>
                            <td class="px-6 py-4">georgeedcaluag@gmail.com</td>
                            <td class="px-6 py-4">LRT</td>
                            <td class="px-6 py-4">
                                <div class="flex space-x-2">
                                    <button class="bg-orange-500 hover:bg-orange-600 text-white px-4 py-1.5 rounded-md text-sm font-semibold transition">
                                        <i class="fas fa-ban mr-1"></i>Deactivate
                                    </button>
                                    <button class="bg-red-500 hover:bg-red-600 text-white px-4 py-1.5 rounded-md text-sm font-semibold transition">
                                        <i class="fas fa-trash mr-1"></i>Delete
