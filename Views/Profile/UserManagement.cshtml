@model woolly_friends.Models.ViewModels.UserDisplay.PaginatedUserViewModel
@{
    var currentUserId = Context.Session.GetInt32("UserId");
}

<!DOCTYPE html>
<html lang="en">
<head>
    <title>User Management</title>
    <meta charset="utf-8" />
    <meta name="description" content="User Management for admins to manage user accounts" />
    <meta name="keywords" content="User Management" />
    <meta name="author" content="Kenzo, Lawrenz, John Cee, Jericho, George" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
</head>
<body class="bg-white font-sans">

    <!-- Profile Section -->


    <!-- Buttons -->
    <div class="flex flex-wrap gap-2 mt-6 px-4 justify-center sm:justify-start">
        <button class="bg-[#c39383] text-[#241612] border border-[#684034] rounded-lg font-black text-lg min-w-[180px] h-[50px] hover:bg-[#b58778] active:bg-[#a77c6e]" onclick="window.location.href='/Profile/Index'">Products</button>
        <button class="bg-[#c39383] text-[#241612] border border-[#684034] rounded-lg font-black text-lg min-w-[180px] h-[50px] hover:bg-[#b58778] active:bg-[#a77c6e]" onclick="window.location.href='/Profile/Orders'">Orders</button>
        <button class="bg-[#c39383] text-[#241612] border border-[#684034] rounded-lg font-black text-lg min-w-[180px] h-[50px] hover:bg-[#b58778] active:bg-[#a77c6e]" onclick="window.location.href='/Profile/Reviews'">Reviews</button>
        <button class="bg-[#c39383] text-[#241612] border border-[#684034] rounded-lg font-black text-lg min-w-[180px] h-[50px] hover:bg-[#b58778] active:bg-[#a77c6e]" onclick="window.location.href='/Profile/UserManagement'">User Management</button>
    </div>

    <!-- User Management Section -->
    <main class="container mx-auto px-4 py-10">
        <div class="bg-white rounded-lg shadow-xl">
            <div class="bg-[#c39383] px-6 py-4 border-b border-gray-300 rounded-t-lg flex justify-between items-center">
                <h2 class="text-xl font-bold text-black">USERS</h2>
                <div class="flex items-center space-x-2">
                    <label for="search" class="font-medium text-black">Search:</label>

                    <div class="relative w-64">
                        <!-- ========== Search Icon ==========-->
                        <svg class="absolute left-3 top-1/2 transform -translate-y-1/2 w-5 h-5 fill-[#412c25]"
                             xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 -960 960 960" width="24px" fill="#e8eaed"><path d="M784-120 532-372q-30 24-69 38t-83 14q-109 0-184.5-75.5T120-580q0-109 75.5-184.5T380-840q109 0 184.5 75.5T640-580q0 44-14 83t-38 69l252 252-56 56ZM380-400q75 0 127.5-52.5T560-580q0-75-52.5-127.5T380-760q-75 0-127.5 52.5T200-580q0 75 52.5 127.5T380-400Z" /></svg>
                        
                        <input type="text"
                               id="search"
                               class="border border-gray-300 rounded-md pl-10 pr-4 py-2 w-full focus:outline-none focus:ring-2 focus:ring-[#684034]"
                               placeholder="Search users...">
                    </div>
                </div>
            </div>

            <!-- Table Headers -->
            <div class="overflow-x-auto">
                <table class="w-full min-w-[1000px]" data-sort-direction="asc">
                    <thead class="bg-[#c39383] text-black">
                        <tr class="border-b border-gray-300 text-sm">
                            <th class="px-6 py-3 text-left font-semibold">ID</th>
                            <th class="px-6 py-3 text-left font-semibold">Username</th>
                            <th class="px-6 py-3 text-left font-semibold">Email</th>
                            <th class="px-6 py-3 text-left font-semibold">Contact No.</th>
                            <th class="px-6 py-3 text-left font-semibold">Role</th>
                            <th class="px-6 py-3 text-left font-semibold">Status</th>
                            <th class="px-6 py-3 text-left font-semibold">Action 1</th>
                            <th class="px-6 py-3 text-left font-semibold">Action 2</th>
                        </tr>
                    </thead>
                    <tbody id="userTableBody" class="text-sm text-black">
                        <!-- Sample rows. Hindi pa sya connected sa db, ikaw na bahala dito George HAHAHHA -->
                        @foreach (var user in Model.Items)
                        {
                            <tr class="border-b border-gray-200 hover:bg-gray-50 even:bg-gray-50 transition">
                                <td class="px-6 py-4">@user.Id</td>
                                <td class="px-6 py-4">@user.Username</td>
                                <td class="px-6 py-4">@user.UserEmail</td>
                                <td class="px-6 py-4">@user.UserContact</td>
                                <td class="px-6 py-4">@user.UserRole</td>
                                <td class="px-6 py-4">
                                    @(user.IsActive ? "Active" : "Deactivated")
                                </td>
                                <td class="px-6 py-4">
                                    <div class="flex space-x-2">
                                        @if (user.Id != currentUserId)
                                        {
                                            <form asp-action="@(user.UserRole == "User" ? "Promote" : "Demote")" asp-controller="Profile" method="post" class="inline">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="userId" value="@user.Id" />
                                                <input type="hidden" name="page" value="@Model.PageNumber" />
                                                <button type="submit" class="bg-orange-500 hover:bg-orange-600 text-white px-4 py-1.5 rounded-md text-sm font-semibold transition">
                                                    @(user.UserRole == "User" ? "Make Admin" : "Make User")
                                                </button>
                                            </form>
                                        }
                                        else
                                        {
                                            <button disabled class="bg-gray-400 text-white px-4 py-1.5 rounded-md text-sm font-semibold cursor-not-allowed">
                                                Make User
                                            </button>
                                        }
                                    </div>
                                </td>
                                <td class="px-6 py-4">
                                    <div class="flex space-x-2">
                                        @if (user.Id != currentUserId)
                                        {
                                            <form asp-action="@(user.IsActive ? "Deactivate" : "Reactivate")" asp-controller="Profile" method="post" class="inline">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="userId" value="@user.Id" />
                                                <input type="hidden" name="page" value="@Model.PageNumber" />
                                                <button type="submit" class="@(user.IsActive ? "bg-red-500 hover:bg-red-600" : "bg-green-500 hover:bg-green-600") text-white px-4 py-1.5 rounded-md text-sm font-semibold transition">
                                                    <i class="fas @(user.IsActive ? "fa-ban" : "fa-check") mr-1"></i>
                                                    @(user.IsActive ? "Deactivate" : "Reactivate")
                                                </button>
                                            </form>
                                        }
                                        else
                                        {
                                            <button disabled class="bg-gray-400 text-white px-4 py-1.5 rounded-md text-sm font-semibold cursor-not-allowed">
                                                <i class="fas @(user.IsActive ? "fa-ban" : "fa-check") mr-1"></i>Deactivate
                                            </button>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <!-- Pagination -->
            <div class="bg-gray-50 px-6 py-4 border-t flex flex-wrap justify-between items-center gap-4">
                <div id="paginationInfo" class="text-sm text-black">
                    Showing @(((Model.PageNumber - 1) * 3) + 1) to @(Math.Min(Model.PageNumber * 3, Model.TotalCount)) of @Model.TotalCount entries
                </div>
                <div class="flex items-center space-x-2">
                    @if (Model.PageNumber > 1)
                    {
                        <a asp-action="UserManagement" asp-controller="Profile" asp-route-page="@(Model.PageNumber - 1)" class="px-3 py-1 text-sm text-black hover:text-[#684034] transition-colors">
                            <svg xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 -960 960 960" width="24px" fill="#684034" class="hover:fill-[#905b4b]">
                                <path d="M560-240 320-480l240-240 56 56-184 184 184 184-56 56Z" />
                            </svg>
                        </a>
                    }

                    <span id="pageBtn" class="px-3 py-1 text-sm bg-[#684034] text-white rounded">@Model.PageNumber</span>

                    @if (Model.PageNumber < Model.TotalPages)
                    {
                        <a asp-action="UserManagement" asp-controller="Profile" asp-route-page="@(Model.PageNumber + 1)" class="px-3 py-1 text-sm text-black hover:text-[#684034] transition-colors">
                            <svg xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 -960 960 960" width="24px" fill="#684034" class="hover:fill-[#905b4b]">
                                <path d="M504-480 320-664l56-56 240 240-240 240-56-56 184-184Z" />
                            </svg>
                        </a>
                    }
                </div>
            </div>
        </div>
    </main>

    <script>
        // For the search function
        document.getElementById('search').addEventListener('input', function () {
            const searchTerm = this.value.toLowerCase();
            const tableRows = document.querySelectorAll('#userTableBody tr');

            tableRows.forEach(row => {
                const text = row.textContent.toLowerCase();
                row.style.display = text.includes(searchTerm) ? '' : 'none';
            });
        });
    </script>
</body>
</html>