@{
    ViewData["Title"] = "Profile";
    ViewBag.Tab = ViewBag.Tab ?? "wishlist";
}

@model woolly_friends.Models.ViewModels.UserProfile.CombinedProfileViewModel

<!DOCTYPE html>
<html lang="en">

<head>
    <title>Profile</title>

    <!-- Pre-requisite Meta Tags -->
    <meta charset="utf-8" />
    <meta name="description" content="Profile page with user credentials." />
    <meta name="keywords" content="Profile, User" />
    <meta name="author" content="Kenzo, Lawrenz, John Cee, Jericho, George" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />

    <link href="~/css/main.css" rel="stylesheet" media="all" />
</head>

<body>

    <!-- Profile Section -->

    @Html.Partial("_UserProfile")

    <hr class="mt-6 border border-[#412c25]" />

    <!-- Tabs (Orders + Wishlist only) -->
    <!-- Buttons -->
    <div class="flex flex-wrap gap-2 mt-6 px-4 justify-center sm:justify-start">
        <form method="get" asp-action="ViewSection" asp-controller="UserProfile">
            <input type="hidden" name="section" value="wishlist" />
            <button type="submit" class="bg-[#c39383] text-[#241612] border border-[#684034] rounded-lg font-black text-lg min-w-[180px] h-[50px] hover:bg-[#b58778] active:bg-[#a77c6e]">
                Wishlist
            </button>
        </form>

        <form method="get" asp-action="ViewSection" asp-controller="UserProfile">
            <input type="hidden" name="section" value="orders" />
            <button type="submit" class="bg-[#c39383] text-[#241612] border border-[#684034] rounded-lg font-black text-lg min-w-[180px] h-[50px] hover:bg-[#b58778] active:bg-[#a77c6e]">
                Orders
            </button>
        </form>
    </div><br />




    <!-- Header -->
    @Html.Partial("_SearchBarHeader")

    <!-- Filter -->
    <div class="container mx-auto mt-8 px-4 flex flex-col md:flex-row gap-6">

        <!-- Sidebar -->
        @Html.Partial("_FilterSidebar")

        <!-- AAAAAAAA -->
        @if (ViewBag.Tab == "wishlist")
        {
            <div class="flex flex-col gap-6 w-full">
                @Html.Partial("_WishlistContent")
                @Html.Partial("_Pagination")
            </div>
        }
        else if (ViewBag.Tab == "orders")
        {
            @Html.Partial("_UserPetTransactionSuccess")
        }


    </div>


    @section Scripts {
        <script>
            document.addEventListener("DOMContentLoaded", function () {
                document.querySelectorAll('.bi-suit-heart, .bi-suit-heart-fill').forEach(function (icon) {
                    icon.addEventListener('click', function () {
                        this.classList.toggle('bi-suit-heart');
                        this.classList.toggle('bi-suit-heart-fill');
                    });
                });
            });

            function toggleFilterSidebar() {
                const sidebar = document.getElementById('mobileFilterSidebar');
                sidebar.classList.toggle('hidden');
            }
        </script>
    }

    <script src="~/js/main.js"></script>
</body>

</html>