@{
    ViewData["Title"] = "Orders";
}

<!DOCTYPE html>
<html lang="en">

<head>
    <title>Orders</title>

    <!-- Pre-requisite Meta Tags -->
    <meta charset="utf-8" />
    <meta name="description" content="Profile page with user credentials." />
    <meta name="keywords" content="Profile, User" />
    <meta name="author" content="Kenzo, Lawrenz, John Cee, Jericho, George" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />

    <link href="~/css/main.css" rel="stylesheet" media="all" />
</head>

<body>
    <div class="container mx-auto mt-4 px-4">
        <nav class="text-lg">
            <ol class="list-reset flex text-gray-700">
                <li><a href="/Home" class="text-blue-600 hover:underline">Home</a></li>
                <li><span class="mx-2">/</span></li>
                <li class="text-gray-500">Orders</li>
            </ol>
        </nav>
    </div>

    <!-- Profile Section -->
    <div class="container mx-auto mt-8 px-4 flex flex-wrap items-start gap-8">
        <div class="w-full md:w-1/4">
            <img src="~/Images/ProfileIcon.png" alt="Profile Picture" class="w-full max-h-72 object-cover border-4 border-black rounded-md" />
        </div>
        <!-- Profile Details with Verified Icon -->
        <div class="flex flex-col gap-2">
            <div class="flex items-center gap-4">
                <h1 class="text-4xl font-bold text-[#684034] font-serif">George Edward</h1>
                <img src="~/Images/VerifiedIcon.png" alt="Verified" class="w-8 h-8" />
            </div>
            <h2 class="text-base font-bold text-black capitalize">Contact Number: 09123456789</h2>
            <h2 class="text-base font-normal text-gray-500">Member Since June 1999</h2>
        </div>
    </div>
        
    <!-- Tabs (Orders + Wishlist only) -->
    <div class="flex gap-2 mt-6 px-4">
            <button class="bg-[#D0C4C0] text-[#241612] border border-[#8B8381] font-black text-lg min-w-[180px] h-[50px] hover:bg-gray-100" onclick="window.location.href='/UserProfile/Index'">Wishlist</button>
            <button class="bg-gray-100 text-[#241612] border border-[#8B8381] font-black text-lg min-w-[180px] h-[50px]">Orders</button>
    </div>


    <!-- Filter Sidebar + Cards -->
    <div class="container mx-auto mt-8 px-4 flex flex-wrap">
        <!-- Sidebar -->
        <aside class="w-full md:w-1/4 bg-white p-5">
            <h4 class="font-bold text-lg flex items-center mb-4">Refine your search</h4>

            <div class="mb-4">
                <h6 class="font-bold mb-2">Species</h6>
                <label class="block"><input type="checkbox" class="mr-2">Cats (0)</label>
                <label class="block"><input type="checkbox" class="mr-2">Dogs (0)</label>
                <label class="block"><input type="checkbox" class="mr-2">Other Pets (0)</label>
            </div>

            <div class="mb-4">
                <h6 class="font-bold mb-2">Gender</h6>
                <label class="block"><input type="checkbox" class="mr-2">Male (0)</label>
                <label class="block"><input type="checkbox" class="mr-2">Female (0)</label>
            </div>

            <div class="mb-4">
                <h6 class="font-bold mb-2">Size</h6>
                <label class="block"><input type="checkbox" class="mr-2">Small (0)</label>
                <label class="block"><input type="checkbox" class="mr-2">Medium (0)</label>
                <label class="block"><input type="checkbox" class="mr-2">Large (0)</label>
            </div>

            <div>
                <h6 class="font-bold mb-2">Price</h6>
                <div class="flex gap-2">
                    <input type="text" placeholder="Min" class="w-1/2 border p-2" />
                    <input type="text" placeholder="Max" class="w-1/2 border p-2" />
                </div>
            </div>
        </aside>

        <!-- Orders Listings -->
        <div class="w-full md:w-3/4 px-3">
            <!-- Ongoing -->
            <h1 class="text-2xl font-bold text-[#684034] mt-4 mb-2">Ongoing</h1>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                @for (int i = 0; i < 2; i++)
                {
                    <div class="relative bg-white rounded-lg shadow-sm hover:shadow-md hover:scale-105 transform transition duration-300 ease-in-out overflow-hidden">
                        <!-- Pet Image -->
                        <img src="~/Images/PetPhotos/Skibidi.jpg" alt="Pet" class="w-full h-64 object-cover" />

                        <!-- Favorite Icon -->
                        <div class="absolute top-2 right-2 w-10 h-10 bg-white rounded-full flex items-center justify-center shadow cursor-pointer">
                            <i class="bi bi-suit-heart text-red-600 text-xl"></i>
                        </div>

                        <!-- Pet Info -->
                        <div class="bg-white px-4 pt-4 pb-4">
                            <h3 class="font-bold text-[#684034] sm:p-1 xl:text-3xl">Skibidi</h3>

                            <div class="text-gray-700 flex items-center gap-1 sm:p-1">
                                <i class="bi bi-heart-fill"></i> Large Male Dog
                            </div>

                            <p class="text-gray-500 sm:p-1">Huge Heart ❤</p>

                            <div class="flex items-center gap-1 sm:p-1">
                                <i class="bi bi-geo-alt-fill"></i> Pureza, Manila
                            </div>

                            <div class="font-bold text-[#0B0B0B] sm:p-1 mt-1">₱5,000</div>
                        </div>
                    </div>
                }
            </div>

            <!-- Success -->
            <h1 class="text-2xl font-bold text-[#684034] mt-10 mb-2">Success</h1>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                @for (int i = 0; i < 2; i++)
                {
                    <div class="relative bg-white rounded-lg shadow-sm hover:shadow-md hover:scale-105 transform transition duration-300 ease-in-out overflow-hidden">
                        <!-- Pet Image -->
                        <img src="~/Images/PetPhotos/Skibidi.jpg" alt="Pet" class="w-full h-64 object-cover" />

                        <!-- Favorite Icon -->
                        <div class="absolute top-2 right-2 w-10 h-10 bg-white rounded-full flex items-center justify-center shadow cursor-pointer">
                            <i class="bi bi-suit-heart text-red-600 text-xl"></i>
                        </div>

                        <!-- Pet Info -->
                        <div class="bg-white px-4 pt-4 pb-4">
                            <h3 class="font-bold text-[#684034] sm:p-1 xl:text-3xl">Skibidi</h3>

                            <div class="text-gray-700 flex items-center gap-1 sm:p-1">
                                <i class="bi bi-heart-fill"></i> Large Male Dog
                            </div>

                            <p class="text-gray-500 sm:p-1">Huge Heart ❤</p>

                            <div class="flex items-center gap-1 sm:p-1">
                                <i class="bi bi-geo-alt-fill"></i> Pureza, Manila
                            </div>

                            <div class="font-bold text-[#0B0B0B] sm:p-1 mt-1">₱5,000</div>
                        </div>
                    </div>
                }
            </div>

            <!-- Failed -->
            <h1 class="text-2xl font-bold text-[#684034] mt-10 mb-2">Failed</h1>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                @for (int i = 0; i < 2; i++)
                {
                    <div class="relative bg-white rounded-lg shadow-sm hover:shadow-md hover:scale-105 transform transition duration-300 ease-in-out overflow-hidden">
                        <!-- Pet Image -->
                        <img src="~/Images/PetPhotos/Skibidi.jpg" alt="Pet" class="w-full h-64 object-cover" />

                        <!-- Favorite Icon -->
                        <div class="absolute top-2 right-2 w-10 h-10 bg-white rounded-full flex items-center justify-center shadow cursor-pointer">
                            <i class="bi bi-suit-heart text-red-600 text-xl"></i>
                        </div>

                        <!-- Pet Info -->
                        <div class="bg-white px-4 pt-4 pb-4">
                            <h3 class="font-bold text-[#684034] sm:p-1 xl:text-3xl">Skibidi</h3>

                            <div class="text-gray-700 flex items-center gap-1 sm:p-1">
                                <i class="bi bi-heart-fill"></i> Large Male Dog
                            </div>

                            <p class="text-gray-500 sm:p-1">Huge Heart ❤</p>

                            <div class="flex items-center gap-1 sm:p-1">
                                <i class="bi bi-geo-alt-fill"></i> Pureza, Manila
                            </div>

                            <div class="font-bold text-[#0B0B0B] sm:p-1 mt-1">₱5,000</div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>

    @section Scripts {
        <script>
            document.addEventListener("DOMContentLoaded", function () {
                document.querySelectorAll('.bi-suit-heart, .bi-suit-heart-fill').forEach(function (icon) {
                    icon.addEventListener('click', function () {
                        this.classList.toggle('bi-suit-heart');
                        this.classList.toggle('bi-suit-heart-fill');
                    });
                });
            });
        </script>
    }

    <script src="~/js/main.js"></script>
</body>
</html>
