@{
    ViewData["Title"] = "Orders";
}

<!DOCTYPE html>
<html lang="en">

<head>
    <title>Orders</title>

    <!-- Pre-requisite Meta Tags -->
    <meta charset="utf-8" />
    <meta name="description" content="Profile page with user credentials." />
    <meta name="keywords" content="Profile, User" />
    <meta name="author" content="Kenzo, Lawrenz, John Cee, Jericho, George" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />

    <link href="~/css/main.css" rel="stylesheet" media="all" />
</head>

<body>
    <div class="container mx-auto mt-4 px-4">
        <nav class="text-lg">
            <ol class="list-reset flex text-gray-700">
                <li><a href="/Home" class="text-blue-600 hover:underline">Home</a></li>
                <li><span class="mx-2">/</span></li>
                <li class="text-gray-500">Orders</li>
            </ol>
        </nav>
    </div>

    <!-- Profile Section -->
    <div class="container mx-auto mt-8 px-4 flex flex-col md:flex-row items-start gap-8">
        <div class="w-full md:w-1/4">
            <img src="~/Images/ProfileIcon.png" alt="Profile Picture" class="w-full max-h-72 object-cover border-4 border-black rounded-md" />
        </div>
        <!-- Profile Details with Verified Icon -->
        <div class="flex flex-col gap-2 w-full md:w-3/4">
            <div class="flex items-center gap-4">
                <h1 class="text-4xl font-bold text-[#684034] font-serif">George Edward</h1>
                <img src="~/Images/VerifiedIcon.png" alt="Verified" class="w-8 h-8" />
            </div>
            <h2 class="text-base font-bold text-black capitalize">Contact Number: 09123456789</h2>
            <h2 class="text-base font-normal text-gray-500">Member Since June 1999</h2>
        </div>
    </div>
        
    <!-- Tabs (Orders + Wishlist only) -->
    <div class="flex flex-wrap gap-2 mt-6 px-4 justify-center sm:justify-start">
        <form method="get" asp-action="Index" asp-controller="UserProfile">
            <button type="submit" class="bg-[#D0C4C0] text-[#241612] border border-[#8B8381] rounded-lg font-black text-lg px-6 py-3 hover:bg-gray-100 transition w-[48%] sm:w-auto min-w-[150px]">
                Wishlist
            </button>
        </form>

        <form method="get" asp-action="ViewSection" asp-controller="UserProfile">
            <input type="hidden" name="section" value="orders" />
            <button type="submit" class="bg-gray-100 text-[#241612] border border-[#8B8381] rounded-lg font-black text-lg px-6 py-3 transition w-[48%] sm:w-auto min-w-[150px]">
                Orders
            </button>
        </form>
    </div>


    <!-- Filter Sidebar + Cards -->
    <div class="container mx-auto mt-8 px-4 flex flex-col md:flex-row gap-6">
        
        <!-- Sidebar -->
        @Html.Partial("_FilterSidebar")


        <!-- Transaction Status -->
        <div class="flex-1 w-full">
            @Html.Partial("_UserPetTransactionStatus")
        </div>
    </div>

    @section Scripts {
        <script>
            document.addEventListener("DOMContentLoaded", function () {
                document.querySelectorAll('.bi-suit-heart, .bi-suit-heart-fill').forEach(function (icon) {
                    icon.addEventListener('click', function () {
                        this.classList.toggle('bi-suit-heart');
                        this.classList.toggle('bi-suit-heart-fill');
                    });
                });
            });

            function toggleFilterSidebar() {
                const sidebar = document.getElementById('mobileFilterSidebar');
                sidebar.classList.toggle('hidden');
            }
        </script>
    }

    <script src="~/js/main.js"></script>
</body>
</html>
