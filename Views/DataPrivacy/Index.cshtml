@{
    ViewData["Title"] = "Data Privacy";
}

<!DOCTYPE html>
<html lang="en">

<head>
    <title>Data Privacy</title>
    <meta charset="utf-8" />
    <meta name="description" content="FAQs page about how to adopt a pet in the Woolly Friends web app." />
    <meta name="keywords" content="FAQs, Questions, Pets, Adopt, Adoption" />
    <meta name="author" content="Kenzo, Lawrenz, John Cee, Jericho, George" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-white font-sans">

    <main class="w-full max-w-screen-xl mx-auto px-4 sm:px-6 lg:px-8 py-10">

        <div>
            <h1 class="text-3xl sm:text-4xl lg:text-5xl text-center text-[#684034] font-bold my-8">Data Privacy</h1>
        </div>

        <div class="border-2 border-[#684034] backdrop-blur-[20px] rounded-xl p-6 sm:p-10 text-justify w-full">

            <strong class="block text-sm sm:text-base mb-6">Effective Date (Last Updated): June 20, 2025</strong>

            <p class="mb-8 indent-8 leading-relaxed">
                Woolly Friends&trade; respects your right to privacy and complies with the provisions
                of the Republic Act No. 10173 (Data Privacy Act of 2012). This Privacy policy explains how Woolly
                Friends&trade; collects, uses, stores, and protects your data upon accessing the web application and using
                the services of Woolly Friends&trade;.
            </p>

            <!-- =============================== Number 1 =============================== -->
            <div class="flex items-center gap-x-2 my-8">
                <h2 class="text-2xl font-bold text-[#684034]">1. Data We Collect</h2>
            </div>

            <p class="mb-4">We collect the following data when you log into Woolly Friends&trade;:</p>

            <ul class="list-disc pl-6 mb-6 space-y-2">
                <li><strong>Full Name:</strong> Useful for contacting the person who bought or adopted a pet.</li>
                <li><strong>Email:</strong> For sending messages and notifications.</li>
                <li><strong>Address:</strong> To check if the adoptees/buyers have a proper shelter.</li>
                <li><strong>Phone Number:</strong> For contacting the adoptees/buyers when they submitted a pet listing request.</li>
                <li><strong>Password:</strong> For securing your account — Only you can access.</li>
                <li><strong>Session Cookies:</strong> To keep you logged in if you don’t log out.</li>
                <li><strong>Reviews:</strong> You are asked to share a review after adopting/buying a pet.</li>
            </ul>

            <!-- =============================== Number 2 =============================== -->
            <div class="flex items-center gap-x-2 my-8">
                <h2 class="text-2xl font-bold text-[#684034]">2. How Woolly Friends Use Your Data</h2>
            </div>

            <p class="mb-4">Woolly Friends&trade; uses your information to:</p>

            <ul class="list-disc pl-6 mb-6 space-y-2">
                <li>Facilitate account registration, access, and management.</li>
                <li>Process adoption or purchase requests.</li>
                <li>Verify your identity and contact you.</li>
                <li>Ensure compliance with related laws and protect you.</li>
            </ul>

            <!-- =============================== Number 3 =============================== -->
            <div class="flex items-center gap-x-2 my-8">
                <h2 class="text-2xl font-bold text-[#684034]">3. Data Sharing</h2>
            </div>

            <p class="mb-4">
                Woolly Friends&trade; values your privacy. Therefore, your information will
                <strong>NOT BE SOLD/SHARED</strong> with third parties, except:
            </p>

            <ul class="list-disc pl-6 mb-6 space-y-2">
                <li><strong>Legal Obligations:</strong> Law enforcement requests or court orders.</li>
                <li><strong>Email Providers:</strong> To contact you.</li>
            </ul>

            <!-- =============================== Number 4 =============================== -->
            <div class="flex items-center gap-x-2 my-8">
                <h2 class="text-2xl font-bold text-[#684034]">4. Data Security</h2>
            </div>

            <p class="mb-4">Woolly Friends&trade; values your privacy.</p>

            <ul class="list-disc pl-6 mb-6 space-y-2">
                <li>Secure server access and password encryption protocols.</li>
                <li>Database protection and server-side authentication measures.</li>
            </ul>

            <!-- =============================== Number 5 =============================== -->
            <div class="flex items-center gap-x-2 my-8">
                <h2 class="text-2xl font-bold text-[#684034]">5. Your Rights as a Data Subject</h2>
            </div>

            <p class="mb-4">Woolly Friends&trade; implements several technical safeguards to secure your data:</p>

            <ul class="list-disc pl-6 mb-6 space-y-2">
                <li><strong>Password hashing:</strong> Not reversible even by admins.</li>
                <li><strong>Anti-Scripting:</strong> Free from script-based attacks.</li>
                <li><strong>Secured Cookies:</strong> Your session data is protected.</li>
            </ul>

            <!-- =============================== Number 6 =============================== -->
            <div class="flex items-center gap-x-2 my-8">
                <h2 class="text-2xl font-bold text-[#684034]">6. Account Deletion and Retention</h2>
            </div>

            <p class="mb-4">As a user, you have the freedom to:</p>

            <ul class="list-disc pl-6 mb-6 space-y-2">
                <li>Delete your account anytime.</li>
                <li>Keep and use your account (subject to moderation for misuse).</li>
            </ul>

            <!-- =============================== Number 7 =============================== -->
            <div class="flex items-center gap-x-2 my-8">
                <h2 class="text-2xl font-bold text-[#684034]">7. Children's Policy</h2>
            </div>

            <p class="mb-6">
                Woolly Friends&trade; services are not intended for children under the age of 13. We do not knowingly
                collect information from children. If you believe a child has submitted data without parental consent,
                contact us at
                <a href="mailto:woollyfriends@gmail.com" class="text-blue-600 hover:text-blue-800">woollyfriends@gmail.com</a>.
            </p>

            <!-- =============================== Number 8 =============================== -->
            <div class="flex items-center gap-x-2 my-8">
                <h2 class="text-2xl font-bold text-[#684034]">8. Cookies and Analytics</h2>
            </div>

            <p class="mb-6">
                We may use cookies to remember your preferences and collect anonymous analytics data.
            </p>

            <!-- =============================== Number 9 =============================== -->
            <div class="flex items-center gap-x-2 my-8">
                <h2 class="text-2xl font-bold text-[#684034]">9. Updates To This Privacy Policy</h2>
            </div>

            <p class="mb-6">
                We may revise this policy from time to time. You will be informed of updates, and the latest version will be available on our website.
            </p>

            <!-- =============================== Number 10 =============================== -->
            <div class="flex items-center gap-x-2 my-8">
                <h2 class="text-2xl font-bold text-[#684034]">10. Contact Us</h2>
            </div>

            <p>
                For questions or concerns, contact us at
                <a href="mailto:woollyfriends@gmail.com" class="text-blue-600 hover:text-blue-800">woollyfriends@gmail.com</a>.
            </p>

        </div>

    </main>


    <script>
        document.addEventListener("DOMContentLoaded", function () {
            document.querySelectorAll('.bi-suit-heart, .bi-suit-heart-fill').forEach(function (icon) {
                icon.addEventListener('click', function () {
                    this.classList.toggle('bi-suit-heart');
                    this.classList.toggle('bi-suit-heart-fill');
                });
            });
        });
    </script>

    <script src="~/js/main.js"></script>
</body>

</html>
