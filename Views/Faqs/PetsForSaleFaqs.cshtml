    <title>Pets For Sale FAQS</title>
    <meta charset="utf-8" />
    <meta name="description" content="FAQs page about how to buy a pet in the Woolly Friends web app." />
    <meta name="keywords" content="FAQs, Questions, Pets, Sale" />
    <meta name="author" content="Kenzo, Lawrenz, John Cee, Jericho, George" />
